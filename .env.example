# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Comma-separated Telegram user IDs allowed to use the bot (@userinfobot)
ALLOWED_USER_IDS=123456789

# Path to config.yaml on the server
CONFIG_PATH=/opt/backup-bot/config.yaml

# Directory for temporary archives and SQLite copies
BACKUP_TMP_DIR=/tmp/backup-bot